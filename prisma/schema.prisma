generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id        String   @id @default(cuid())
  nombre    String?
  email     String?  @unique
  telefono  String?
  role      String?
  password  String
  createdAt DateTime @default(now())
}

model Cliente {
  id                     String        @id @default(cuid())
  nombre                 String
  telefono               String?
  whatsapp               String?
  nombre_negocio         String?
  email                  String?
  estado                 EstadoCliente @default(PENDIENTE)
  fuenteExterna          String?
  cuentaPrueba           Boolean       @default(true)
  fechaIngreso           DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  tipoCliente            TipoCliente?  @default(PAGINA_WEB)
  plan                   Plan?
  demoPresentada         Boolean       @default(false)
  fechaDemo              DateTime?
  demoReseña            DemoReseña?
  fechaReseña           DateTime?
  notaReseña            String?
  notasInicialesCRM      String?
  fechaNotasInicialesCRM DateTime?
  compraRealizada        Boolean       @default(false)
  fechaCompra            DateTime?
  montoTotal             Decimal?      @db.Decimal(10, 2)
  avisos                 Aviso[]
  notas                  Nota[]
  pagos                  Pago[]
  seguimientos           Seguimiento[]
}

model Seguimiento {
  id         String            @id @default(cuid())
  clienteId  String
  dia        Int
  estado     EstadoSeguimiento @default(PENDIENTE)
  fechaProg  DateTime
  fechaEnvio DateTime?
  mensaje    String?
  createdAt  DateTime          @default(now())
  cliente    Cliente           @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([clienteId], map: "Seguimiento_clienteId_fkey")
}

model Transaccion {
  id          String          @id @default(cuid())
  tipo        TipoTransaccion
  monto       Decimal         @db.Decimal(10, 2)
  descripcion String
  categoria   String
  fecha       DateTime        @default(now())
  creadoPor   String
  createdAt   DateTime        @default(now())
}

model Aviso {
  id                       String      @id @default(cuid())
  titulo                   String
  mensaje                  String
  telefono                 String
  fechaProg                DateTime
  estado                   EstadoAviso @default(PENDIENTE)
  clienteId                String?
  creadoPor                String
  createdAt                DateTime    @default(now())
  recordatorio1hEnviado    Boolean     @default(false)
  recordatorio30minEnviado Boolean     @default(false)
  recordatorio10minEnviado Boolean     @default(false)
  cliente                  Cliente?    @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([clienteId], map: "Aviso_clienteId_fkey")
}

model Configuracion {
  key   String @id
  value String @db.Text
}

model Nota {
  id        String   @id @default(cuid())
  clienteId String
  contenido String   @db.Text
  tipo      String?
  fechaNota DateTime @default(now())
  analizado Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cliente   Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([clienteId], map: "Nota_clienteId_fkey")
}

model Pago {
  id        String     @id @default(cuid())
  clienteId String
  monto     Decimal    @db.Decimal(10, 2)
  metodo    MetodoPago
  estado    EstadoPago @default(PENDIENTE)
  fechaPago DateTime?
  notas     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  cliente   Cliente    @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([clienteId], map: "Pago_clienteId_fkey")
}

model ChatMessage {
  id        String   @id @default(cuid())
  role      String
  content   String   @db.Text
  asesor    String
  createdAt DateTime @default(now())
}

enum EstadoCliente {
  PENDIENTE
  ENVIADO
  PAGADO
  CERRADO
}

enum TipoCliente {
  CRM
  PAGINA_WEB
  ACTIVAQ
}

enum Plan {
  BASIC
  BUSINESS
  CATALOG
}

enum DemoReseña {
  INTERESADO
  NO_INTERESADO
  VOLVER_A_PRESENTAR
}

enum EstadoSeguimiento {
  PENDIENTE
  ENVIADO
  OMITIDO
}

enum TipoTransaccion {
  INGRESO
  GASTO
}

enum EstadoAviso {
  PENDIENTE
  ENVIADO
  FALLIDO
}

enum MetodoPago {
  EFECTIVO
  TRANSFERENCIA
  TARJETA
}

enum EstadoPago {
  PENDIENTE
  COMPLETADO
  CANCELADO
}
